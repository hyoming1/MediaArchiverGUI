<Application x:Class="MediaArchiver.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>

        <!-- ── 색상 팔레트 ─────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BrBg"        Color="#0F1117"/>
        <SolidColorBrush x:Key="BrSurface"   Color="#1A1D27"/>
        <SolidColorBrush x:Key="BrBorder"    Color="#2A2D3E"/>
        <SolidColorBrush x:Key="BrAccent"    Color="#4F8EF7"/>
        <SolidColorBrush x:Key="BrSuccess"   Color="#34D399"/>
        <SolidColorBrush x:Key="BrWarn"      Color="#FBBF24"/>
        <SolidColorBrush x:Key="BrError"     Color="#F87171"/>
        <SolidColorBrush x:Key="BrText"      Color="#E8EAF2"/>
        <SolidColorBrush x:Key="BrTextMuted" Color="#6B7280"/>

        <!-- ── 기본 TextBlock ──────────────────────────────────────── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrText}"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <!-- ── 카드 Border ────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BrSurface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="16"/>
        </Style>

        <!-- ── 버튼 공통 템플릿 ───────────────────────────────────── -->
        <ControlTemplate x:Key="RoundedButtonTemplate" TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Bd" Property="Opacity" Value="0.32"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="FontFamily"      Value="Consolas, Courier New"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="Template"
                    Value="{StaticResource RoundedButtonTemplate}"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource BrAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource BrBorder}"/>
            <Setter Property="Foreground" Value="{StaticResource BrText}"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="{StaticResource BrError}"/>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button"
               BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrTextMuted}"/>
            <Setter Property="Padding"    Value="8,4"/>
        </Style>

        <!-- ── TextBox ────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BrBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrText}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontFamily"      Value="Consolas, Courier New"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="{StaticResource BrAccent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ProgressBar ───────────────────────────────────────── -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height"          Value="4"/>
            <Setter Property="Background"      Value="{StaticResource BrBorder}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrAccent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left"
                                        CornerRadius="2"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CheckBox ──────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BrTextMuted}"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

    </Application.Resources>
</Application>
